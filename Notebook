    "## 7. Statistical Hypothesis Testing <a id='7'></a>\n",
    "\n",
    "Validating findings with formal statistical tests.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5f35a617",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Chi-Square (Sex vs Survived):  χ²=363.2,  p=1.49e-81,  dof=1\n",
      "Chi-Square (Class vs Survived): χ²=127.9, p=1.45e-28,  dof=2\n",
      "T-test (Age): t=3.043, p=0.0024  (Significant)\n",
      "Mann-Whitney U (Fare): U=138501.0, p=6.12e-32 (Significant)\n"
     ]
    }
   ],
   "source": [
    "from scipy import stats\n",
    "\n",
    "# 7a — Chi-square: Sex vs Survival\n",
    "ct_sex = pd.crosstab(df['sex'], df['survived'])\n",
    "chi2, p_sex, dof, _ = stats.chi2_contingency(ct_sex)\n",
    "print(f\"Chi-Square (Sex vs Survived):  χ²={chi2:.1f},  p={p_sex:.2e},  dof={dof}\")\n",
    "\n",
    "# 7b — Chi-square: Pclass vs Survival\n",
    "ct_cls = pd.crosstab(df['pclass'], df['survived'])\n",
    "chi2_c, p_cls, dof_c, _ = stats.chi2_contingency(ct_cls)\n",
    "print(f\"Chi-Square (Class vs Survived): χ²={chi2_c:.1f}, p={p_cls:.2e},  dof={dof_c}\")\n",
    "\n",
    "# 7c — T-test: Age (survived vs not)\n",
    "surv_age = df[df['survived']==1]['age'].dropna()\n",
    "dead_age = df[df['survived']==0]['age'].dropna()\n",
    "t, p_age = stats.ttest_ind(surv_age, dead_age)\n",
    "print(f\"T-test (Age): t={t:.3f}, p={p_age:.4f}  ({'Significant' if p_age<0.05 else 'Not significant'})\")\n",
    "\n",
    "# 7d — Mann-Whitney U: Fare (survived vs not)\n",
    "surv_fare = df[df['survived']==1]['fare'].dropna()\n",
    "dead_fare = df[df['survived']==0]['fare'].dropna()\n",
    "u, p_fare = stats.mannwhitneyu(surv_fare, dead_fare, alternative='two-sided')\n",
    "print(f\"Mann-Whitney U (Fare): U={u:.0f}, p={p_fare:.2e} (Significant)\")"
   ]
  },
