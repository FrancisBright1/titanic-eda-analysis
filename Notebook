   ],
   "source": [
    "# Engineered features\n",
    "df['title'] = df['name'].str.extract(r',\\s*([^\\.]+)\\.')\n",
    "df['title'] = df['title'].replace({\n",
    "    'Mlle':'Miss','Mme':'Mrs','Ms':'Miss',\n",
    "    'Don':'Rare','Dona':'Rare','Rev':'Rare','Dr':'Rare',\n",
    "    'Major':'Rare','Lady':'Rare','Sir':'Rare',\n",
    "    'Col':'Rare','Capt':'Rare','Countess':'Rare','Jonkheer':'Rare'\n",
    "})\n",
    "df['family_size'] = df['sibsp'] + df['parch'] + 1\n",
    "df['is_alone']    = (df['family_size'] == 1).astype(int)\n",
    "df['has_cabin']   = df['cabin'].notna().astype(int)\n",
    "df['age_band']    = pd.cut(df['age'], bins=[0,12,18,35,60,100],\n",
    "                           labels=['Child','Teen','Adult','Middle-Age','Senior'])\n",
    "df['fare_band']   = pd.qcut(df['fare'].fillna(df['fare'].median()), 4,\n",
    "                            labels=['Low','Medium','High','Very High'])\n",
    "df['log_fare']    = np.log1p(df['fare'])\n",
    "\n",
    "print(\"New features added:\", ['title','family_size','is_alone','has_cabin',\n",
    "                               'age_band','fare_band','log_fare'])\n",
    "print(f\"\\nTitle distribution:\\n{df['title'].value_counts().to_string()}\")"
   ]
  },
